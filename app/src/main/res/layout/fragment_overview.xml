<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".features.overview.OverviewFragment">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="歡迎回來，老闆"
        android:textAppearance="?attr/textAppearanceLabelLarge"
        android:textColor="?attr/colorOutline"/>

    <include
        android:id="@+id/layout_summary"
        layout="@layout/view_today_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="本月概況"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:textColor="?attr/colorOutline" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="累積營業額"
                android:textAppearance="?attr/textAppearanceLabelSmall" />
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$ 0"
                android:textAppearance="?attr/textAppearanceTitleLarge" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="已完成訂單"
                android:textAppearance="?attr/textAppearanceLabelSmall" />
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 筆"
                android:textAppearance="?attr/textAppearanceTitleLarge" />
        </LinearLayout>
    </LinearLayout> <com.google.android.material.textview.MaterialTextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="40dp"
    android:text="最近動態"
    android:textAppearance="?attr/textAppearanceTitleMedium" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tv_recent_activity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="尚無動態"
        android:lineHeight="24sp"
        android:textAppearance="?attr/textAppearanceBodyMedium" />

</LinearLayout>